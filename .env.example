# Example env vars - referenced via `url_env` in config.yaml
# Copy to .env and fill with your READ-ONLY DB users.
# See docs/setup-db-readonly.md for how to create those users.

ANALYTICS_PROD_URL=postgresql+psycopg2://ai_readonly:password@host:5432/analytics
LOCAL_MYSQL_URL=mysql+pymysql://ai_readonly:password@localhost:3306/shop
